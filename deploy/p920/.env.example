# AOS-M.1 headroom P920 deploy — kopieer naar `.env` (gitignored) en vul in.
# In CI/CD wordt dit gerenderd uit repo-secret HEADROOM_UPSTREAM_URL + vars.

# VERPLICHT — de MarQed LiteLLM-gateway (OpenAI-compatible base). headroom comprimeert → forwardt hierheen.
HEADROOM_UPSTREAM_URL=http://<litellm-gateway-host>:<port>/v1

# Tailscale-only bind (P920 = marqed003). Default 100.84.112.24:8790.
HEADROOM_BIND_IP=100.84.112.24
HEADROOM_PORT=8790

# Compressie-tuning (optioneel; defaults in compose).
HEADROOM_MIN_TOKENS=200
HEADROOM_SAVINGS_TARGET=0.50

# Alleen bij --profile semantic:
NEO4J_AUTH=neo4j/change-me
