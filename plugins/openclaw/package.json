{
  "name": "headroom-openclaw",
  "version": "0.26.0",
  "description": "Headroom context compression plugin for OpenClaw — 70-90% token savings with zero LLM calls",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "hook-shim",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsup && node prepare-dist.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "headroom-ai": "^0.22.3"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.5"
  },
  "openclaw": {
    "hooks": [
      "./hook-shim"
    ],
    "extensions": [
      "./dist/index.js"
    ],
    "capabilities": {
      "network": {
        "allow": [
          "http://*:*",
          "https://*:*"
        ]
      }
    }
  },
  "license": "Apache-2.0"
}
